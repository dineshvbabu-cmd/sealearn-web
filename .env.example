NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_xxxxx
PAYSTACK_WEBHOOK_SECRET=replace-me
FLUTTERWAVE_SECRET_KEY=FLWSECK_xxxxx
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_xxxxx

# Optional AI integrations
