// SeaLearn Nigeria — Prisma Schema
// Railway PostgreSQL · Prisma 6

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// AUTH & USERS
// ─────────────────────────────────────────────────────────────

enum Role {
  GUEST
  CADET
  STUDENT
  INSTRUCTOR
  LMS_ADMIN
  REGISTRAR
  ADMIN
  SUPER_ADMIN
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String
  phone         String?
  nin           String?   @unique  // Nigerian NIN
  role          Role      @default(STUDENT)
  passwordHash  String?
  image         String?
  mfaEnabled    Boolean   @default(false)
  mfaSecret     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  applications  Application[]
  enrolments    Enrolment[]
  payments      Payment[]
  practicalLogs PracticalLog[]
  examAttempts  ExamAttempt[]
  certificates  Certificate[]
  permissions   UserPermission[]
  virTemplatesCreated        VirTemplate[]          @relation("VirTemplateCreatedBy")
  virInspectionsCreated      VirInspection[]        @relation("VirInspectionCreatedBy")
  virInspectionsInspected    VirInspection[]        @relation("VirInspectionInspector")
  virInspectionsShoreReviewed VirInspection[]       @relation("VirInspectionShoreReviewer")
  virAnswersAnswered         VirAnswer[]            @relation("VirAnswerAnsweredBy")
  virFindingsCreated         VirFinding[]           @relation("VirFindingCreatedBy")
  virFindingsOwned           VirFinding[]           @relation("VirFindingOwner")
  virFindingsClosed          VirFinding[]           @relation("VirFindingClosedBy")
  virPhotosUploaded          VirPhoto[]             @relation("VirPhotoUploadedBy")
  virActionsOwned            VirCorrectiveAction[]  @relation("VirActionOwner")
  virActionsVerified         VirCorrectiveAction[]  @relation("VirActionVerifiedBy")
  virSignOffs                VirSignOff[]
  virImportSessions          VirImportSession[]     @relation("VirImportCreatedBy")
  virImportReviews           VirImportFieldReview[] @relation("VirImportReviewer")
  // Instructor relations
  taughtCourses Course[]         @relation("InstructorCourses")
  gradedLogs    PracticalLog[]   @relation("InstructorSignOff")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────
// COURSES
// ─────────────────────────────────────────────────────────────

enum CourseLevel {
  PRE_SEA
  SHORT_COURSE
  DEGREE
  POST_COC
  REFRESHER
}

enum RegistrationFormType {
  GOOGLE_FORM
  MS_FORM
}

model Course {
  id                   String               @id @default(cuid())
  slug                 String               @unique
  title                String
  stcwRegulation       String?              // e.g. "VI/1", "II/1"
  imoModelCourse       String?
  level                CourseLevel
  durationWeeks        Int
  feeNaira             Int                  @default(0)
  applicationFee       Int                  @default(0)
  description          String               @db.Text
  eligibility          String               @db.Text
  outcomes             String               @db.Text
  isActive             Boolean              @default(true)
  nimasaApproved       Boolean              @default(true)
  nimasaRefNumber      String?
  registrationFormType RegistrationFormType @default(MS_FORM)
  registrationFormUrl  String?              // link to Google/MS form
  imageUrl             String?              // course card image
  instructorId         String?
  instructor           User?                @relation("InstructorCourses", fields: [instructorId], references: [id])
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  modules          Module[]
  applications     Application[]
  enrolments       Enrolment[]
  intakeDates      IntakeDate[]
  resources        CourseResource[]
  packages         CoursePackageCourse[]
  priceRequests    PriceRequest[]
}

model IntakeDate {
  id          String   @id @default(cuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id])
  startDate   DateTime
  endDate     DateTime
  deadline    DateTime
  isOpen      Boolean  @default(true)
  capacity    Int      @default(30)
  enrolments  Enrolment[]
  applications Application[]
}

model Module {
  id          String    @id @default(cuid())
  courseId    String
  course      Course    @relation(fields: [courseId], references: [id])
  title       String
  order       Int
  videoUrl    String?   // Cloudflare Stream URL
  scormUrl    String?   // R2 path
  pdfUrl      String?   // R2 path
  durationMin Int?
  lessons     Lesson[]
  quizzes     Quiz[]
}

model Lesson {
  id         String  @id @default(cuid())
  moduleId   String
  module     Module  @relation(fields: [moduleId], references: [id])
  title      String
  order      Int
  videoUrl   String?
  pdfUrl     String?
  durationMin Int?
}

// ─────────────────────────────────────────────────────────────
// ADMISSIONS
// ─────────────────────────────────────────────────────────────

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  ACCEPTED
  REJECTED
  WAITLISTED
}

model Application {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id])
  courseId        String
  course          Course            @relation(fields: [courseId], references: [id])
  intakeDateId    String?
  intakeDate      IntakeDate?       @relation(fields: [intakeDateId], references: [id])
  status          ApplicationStatus @default(DRAFT)
  // Personal
  dateOfBirth     DateTime?
  gender          String?
  stateOfOrigin   String?
  lga             String?
  address         String?
  // Documents (R2 paths)
  passportPhotoUrl  String?
  waecResultUrl     String?
  ninDocUrl         String?
  medicalCertUrl    String?  // ML5 or ENG1
  seaServiceUrl     String?
  // Next of kin
  nokName         String?
  nokRelationship String?
  nokPhone        String?
  // Meta
  appFeePaymentId String?
  submittedAt     DateTime?
  reviewedAt      DateTime?
  reviewedBy      String?
  reviewNotes     String?   @db.Text
  offerLetterUrl  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ─────────────────────────────────────────────────────────────
// ENROLMENTS & PAYMENTS
// ─────────────────────────────────────────────────────────────

enum EnrolmentStatus {
  PENDING_PAYMENT
  ACTIVE
  COMPLETED
  SUSPENDED
  WITHDRAWN
}

model Enrolment {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id])
  courseId       String
  course         Course          @relation(fields: [courseId], references: [id])
  intakeDateId   String?
  intakeDate     IntakeDate?     @relation(fields: [intakeDateId], references: [id])
  status         EnrolmentStatus @default(PENDING_PAYMENT)
  totalFee       Int
  amountPaid     Int             @default(0)
  scholarshipCode String?
  discountAmount Int             @default(0)
  startDate      DateTime?
  endDate        DateTime?
  completedAt    DateTime?
  stepLmsUrl     String?         // deep link to Step LMS course
  lmsActive      Boolean         @default(false)
  lmsRevokedAt   DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  payments       Payment[]
  progress       ModuleProgress[]
  practicalLogs  PracticalLog[]
  certificates   Certificate[]
}

enum PaymentMethod {
  PAYSTACK_CARD
  PAYSTACK_BANK
  FLUTTERWAVE
  USSD
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

model Payment {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  enrolmentId     String?
  enrolment       Enrolment?    @relation(fields: [enrolmentId], references: [id])
  amountNaira     Int
  nimasaFee       Int           @default(0)
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  reference       String        @unique
  providerRef     String?
  receiptUrl      String?       // R2 path
  metadata        Json?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
}

// ─────────────────────────────────────────────────────────────
// LMS PROGRESS
// ─────────────────────────────────────────────────────────────

model ModuleProgress {
  id           String    @id @default(cuid())
  enrolmentId  String
  enrolment    Enrolment @relation(fields: [enrolmentId], references: [id])
  moduleId     String
  percentDone  Int       @default(0)
  completedAt  DateTime?
  updatedAt    DateTime  @updatedAt
  @@unique([enrolmentId, moduleId])
}

// ─────────────────────────────────────────────────────────────
// PRACTICAL LOG (STCW Sea-Service Record)
// ─────────────────────────────────────────────────────────────

model PracticalLog {
  id              String    @id @default(cuid())
  enrolmentId     String
  enrolment       Enrolment @relation(fields: [enrolmentId], references: [id])
  studentId       String
  student         User      @relation(fields: [studentId], references: [id])
  stcwItem        String    // e.g. "Table A-II/1 item 3"
  description     String    @db.Text
  hoursLogged     Float
  date            DateTime
  signedById      String?
  signedBy        User?     @relation("InstructorSignOff", fields: [signedById], references: [id])
  signedAt        DateTime?
  signatureUrl    String?   // R2 path to e-signature
  createdAt       DateTime  @default(now())
}

// ─────────────────────────────────────────────────────────────
// EXAMINATIONS
// ─────────────────────────────────────────────────────────────

model Quiz {
  id        String     @id @default(cuid())
  moduleId  String
  module    Module     @relation(fields: [moduleId], references: [id])
  title     String
  timeLimitMin Int     @default(30)
  passMark  Int        @default(70)
  questions Question[]
  attempts  ExamAttempt[]
}

model Question {
  id        String   @id @default(cuid())
  quizId    String
  quiz      Quiz     @relation(fields: [quizId], references: [id])
  text      String   @db.Text
  type      String   @default("MCQ")  // MCQ, TRUE_FALSE, SHORT
  options   Json?    // [{text, isCorrect}]
  answer    String?
  stcwRef   String?
  marks     Int      @default(1)
  order     Int
}

model ExamAttempt {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  quizId      String
  quiz        Quiz     @relation(fields: [quizId], references: [id])
  answers     Json     // {questionId: answer}
  score       Int?
  passed      Boolean?
  startedAt   DateTime @default(now())
  submittedAt DateTime?
  ipAddress   String?
}

// ─────────────────────────────────────────────────────────────
// CERTIFICATES
// ─────────────────────────────────────────────────────────────

model Certificate {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  enrolmentId     String
  enrolment       Enrolment @relation(fields: [enrolmentId], references: [id])
  type            String    // e.g. "BST", "GMDSS", "PRE_SEA_DECK"
  nimasaNumber    String    @unique
  stcwRegulation  String?
  issueDate       DateTime  @default(now())
  expiryDate      DateTime?
  pdfUrl          String    // R2 path
  qrCode          String    // verification URL
  isRevoked       Boolean   @default(false)
  createdAt       DateTime  @default(now())
}

// ─────────────────────────────────────────────────────────────
// NEWS & EVENTS
// ─────────────────────────────────────────────────────────────

model Post {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String?
  body        String   @db.Text
  imageUrl    String?
  category    String   @default("news")  // news | event | announcement
  authorId    String?
  publishedAt DateTime?
  eventDate   DateTime?
  eventVenue  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// SITE CMS CONTENT
// ─────────────────────────────────────────────────────────────

model SiteConfig {
  id        String   @id @default(cuid())
  section   String   // homepage | contact | about | admissions | general | footer
  key       String
  value     String   @db.Text
  type      String   @default("text") // text | textarea | url | boolean
  label     String
  sortOrder Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([section, key])
}

// ─────────────────────────────────────────────────────────────
// COURSE PACKAGES (Bundles with discounts)
// ─────────────────────────────────────────────────────────────

model CoursePackage {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  description     String?  @db.Text
  discountPercent Int      @default(0)    // e.g. 15 = 15% off total fee
  isActive        Boolean  @default(true)
  badgeText       String   @default("Bundle Offer")
  badgeColor      String   @default("bg-teal")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  courses         CoursePackageCourse[]
}

model CoursePackageCourse {
  packageId  String
  courseId   String
  package    CoursePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  course     Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  @@id([packageId, courseId])
}

// ─────────────────────────────────────────────────────────────
// NEWSLETTER SUBSCRIBERS
// ─────────────────────────────────────────────────────────────

model Subscriber {
  id          String   @id @default(cuid())
  email       String   @unique
  confirmedAt DateTime?
  createdAt   DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────
// COURSE RESOURCES (Library)
// ─────────────────────────────────────────────────────────────

model CourseResource {
  id          String   @id @default(cuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  type        String   // video | pdf | ppt | doc | image
  url         String   @db.Text  // R2 URL, YouTube embed, or external URL
  storageKey  String?  // R2 object key for managed files
  description String?  @db.Text
  fileSize    String?  // human-readable, e.g. "2.4 MB"
  duration    String?  // for videos, e.g. "12:34"
  topic       String?  // e.g. "Navigation", "Safety", "Cargo"
  sortOrder   Int      @default(0)
  isPublic    Boolean  @default(false) // visible without enrollment
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// ACTIVITY LOG (Audit Trail)
// ─────────────────────────────────────────────────────────────

model ActivityLog {
  id          String   @id @default(cuid())
  actorId     String?  // null = system
  actorName   String?
  actorRole   String?
  action      String   // e.g. "UPDATED_CMS", "APPROVED_APPLICATION", "ENROLLED_STUDENT"
  entity      String   // e.g. "SiteConfig", "Application", "Enrolment"
  entityId    String?
  entityLabel String?  // human-readable name
  detail      String?  @db.Text
  ipAddress   String?
  createdAt   DateTime @default(now())

  @@index([actorId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────
// WAITLIST
// ─────────────────────────────────────────────────────────────

enum WaitlistStatus {
  WAITING
  NOTIFIED
  ENROLLED
  EXPIRED
}

model Waitlist {
  id          String        @id @default(cuid())
  userId      String
  courseId    String
  intakeDateId String?
  status      WaitlistStatus @default(WAITING)
  notes       String?        @db.Text
  staffNotes  String?        @db.Text
  notifiedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// ─────────────────────────────────────────────────────────────
// PRICE REQUESTS
// ─────────────────────────────────────────────────────────────

enum PriceRequestStatus {
  NEW
  REPLIED
  CLOSED
}

model PriceRequest {
  id        String             @id @default(cuid())
  name      String
  email     String
  phone     String?
  courseId  String?
  course    Course?            @relation(fields: [courseId], references: [id])
  message   String?            @db.Text
  status    PriceRequestStatus @default(NEW)
  repliedAt DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────
// USER PERMISSIONS (per-user page access control)
// ─────────────────────────────────────────────────────────────

model UserPermission {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource  String   // admin page slug, e.g. "courses", "applications", "payments"
  canView   Boolean  @default(true)
  canEdit   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, resource])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────
// HELP VIDEOS
// ─────────────────────────────────────────────────────────────

model HelpVideo {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  videoUrl    String   @db.Text  // YouTube embed URL or direct video URL
  thumbnailUrl String?
  category    String   @default("general")  // general | admissions | portal | lms | stcw
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([sortOrder])
}

// ─────────────────────────────────────────────────────────────
// EMAIL TEMPLATES
// ─────────────────────────────────────────────────────────────

model EmailTemplate {
  id          String   @id @default(cuid())
  slug        String   @unique  // e.g. "offer-letter", "welcome", "fee-quote"
  name        String            // human-readable name
  subject     String
  bodyHtml    String   @db.Text
  variables   String?  @db.Text // JSON string: [{name, description, example}]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// LEADERSHIP TEAM
// ─────────────────────────────────────────────────────────────

model LeadershipMember {
  id         String   @id @default(cuid())
  name       String
  title      String
  credential String?
  bio        String?  @db.Text
  imageUrl   String?
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum VirInspectionTypeCategory {
  VETTING
  PSC
  CLASS
  INTERNAL
  AUDIT
}

enum VirInspectionStatus {
  DRAFT
  SUBMITTED
  RETURNED
  SHORE_REVIEWED
  CLOSED
  IMPORT_REVIEW
  ARCHIVED
}

enum VirQuestionResponseType {
  YES_NO_NA
  TEXT
  NUMBER
  DATE
  SINGLE_SELECT
  MULTI_SELECT
  SCORE
}

enum VirRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum VirFindingType {
  NON_CONFORMITY
  OBSERVATION
  RECOMMENDATION
  POSITIVE
}

enum VirFindingStatus {
  OPEN
  IN_PROGRESS
  READY_FOR_REVIEW
  CLOSED
  CARRIED_OVER
}

enum VirCorrectiveActionStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  VERIFIED
  REJECTED
}

enum VirSignOffStage {
  VESSEL_SUBMISSION
  SHORE_REVIEW
  FINAL_ACKNOWLEDGEMENT
}

enum VirImportStatus {
  QUEUED
  PROCESSING
  REVIEW
  READY
  COMMITTED
  FAILED
}

model Vessel {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  imoNumber   String?  @unique
  vesselType  String?
  fleet       String?
  flag        String?
  manager     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  virInspections    VirInspection[]
  virImportSessions VirImportSession[]

  @@index([name])
  @@index([fleet])
}

model VirInspectionType {
  id          String                    @id @default(cuid())
  code        String                    @unique
  name        String
  category    VirInspectionTypeCategory
  description String?                   @db.Text
  isActive    Boolean                   @default(true)
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  templates      VirTemplate[]
  inspections    VirInspection[]
  importSessions VirImportSession[]

  @@index([category])
  @@index([name])
}

model VirTemplate {
  id               String   @id @default(cuid())
  inspectionTypeId String
  name             String
  version          String
  description      String?  @db.Text
  isActive         Boolean  @default(true)
  createdById      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  inspectionType VirInspectionType @relation(fields: [inspectionTypeId], references: [id], onDelete: Cascade)
  createdBy      User?             @relation("VirTemplateCreatedBy", fields: [createdById], references: [id])
  sections       VirTemplateSection[]
  inspections    VirInspection[]

  @@unique([inspectionTypeId, version])
  @@index([isActive])
}

model VirTemplateSection {
  id         String   @id @default(cuid())
  templateId String
  code       String?
  title      String
  guidance   String?  @db.Text
  sortOrder  Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  template  VirTemplate           @relation(fields: [templateId], references: [id], onDelete: Cascade)
  questions VirTemplateQuestion[]

  @@unique([templateId, sortOrder])
  @@index([templateId, code])
}

model VirTemplateQuestion {
  id               String                  @id @default(cuid())
  sectionId        String
  code             String
  prompt           String                  @db.Text
  responseType     VirQuestionResponseType
  riskLevel        VirRiskLevel            @default(LOW)
  isMandatory      Boolean                 @default(false)
  allowsObservation Boolean                @default(true)
  allowsPhoto      Boolean                 @default(true)
  isCicCandidate   Boolean                 @default(false)
  cicTopic         String?
  helpText         String?                 @db.Text
  referenceImageUrl String?
  sortOrder        Int
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  section  VirTemplateSection       @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  options  VirTemplateQuestionOption[]
  answers  VirAnswer[]
  findings VirFinding[]

  @@unique([sectionId, code])
  @@unique([sectionId, sortOrder])
  @@index([responseType])
  @@index([riskLevel])
}

model VirTemplateQuestionOption {
  id         String   @id @default(cuid())
  questionId String
  value      String
  label      String
  score      Int?
  sortOrder  Int      @default(0)

  question VirTemplateQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, value])
  @@unique([questionId, sortOrder])
}

model VirInspection {
  id                String              @id @default(cuid())
  vesselId          String
  inspectionTypeId  String
  templateId        String?
  title             String
  externalReference String?
  inspectionDate    DateTime
  port              String?
  country           String?
  inspectorName     String?
  inspectorCompany  String?
  vesselMasterName  String?
  chiefEngineerName String?
  summary           String?             @db.Text
  status            VirInspectionStatus @default(DRAFT)
  previousInspectionId String?
  posCount          Int                 @default(0)
  obsCount          Int                 @default(0)
  ncCount           Int                 @default(0)
  recCount          Int                 @default(0)
  createdById       String?
  inspectorUserId   String?
  shoreReviewedById String?
  shoreReviewDate   DateTime?
  closedAt          DateTime?
  importSessionId   String?
  metadata          Json?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  vessel             Vessel             @relation(fields: [vesselId], references: [id], onDelete: Cascade)
  inspectionType     VirInspectionType  @relation(fields: [inspectionTypeId], references: [id])
  template           VirTemplate?       @relation(fields: [templateId], references: [id])
  previousInspection VirInspection?     @relation("VirPreviousInspection", fields: [previousInspectionId], references: [id])
  nextInspections    VirInspection[]    @relation("VirPreviousInspection")
  createdBy          User?              @relation("VirInspectionCreatedBy", fields: [createdById], references: [id])
  inspectorUser      User?              @relation("VirInspectionInspector", fields: [inspectorUserId], references: [id])
  shoreReviewedBy    User?              @relation("VirInspectionShoreReviewer", fields: [shoreReviewedById], references: [id])
  importSession      VirImportSession?  @relation(fields: [importSessionId], references: [id])
  answers            VirAnswer[]
  findings           VirFinding[]
  signOffs           VirSignOff[]
  photos             VirPhoto[]

  @@index([vesselId, inspectionDate])
  @@index([inspectionTypeId, inspectionDate])
  @@index([status])
}

model VirAnswer {
  id              String    @id @default(cuid())
  inspectionId    String
  questionId      String
  answerText      String?   @db.Text
  answerNumber    Float?
  answerBoolean   Boolean?
  answerDate      DateTime?
  selectedOptions Json?
  comment         String?   @db.Text
  answeredById    String?
  answeredAt      DateTime?
  evidenceCount   Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  inspection VirInspection       @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  question   VirTemplateQuestion @relation(fields: [questionId], references: [id])
  answeredBy User?               @relation("VirAnswerAnsweredBy", fields: [answeredById], references: [id])
  photos     VirPhoto[]

  @@unique([inspectionId, questionId])
}

model VirFinding {
  id                  String           @id @default(cuid())
  inspectionId        String
  questionId          String?
  findingType         VirFindingType
  severity            VirRiskLevel     @default(MEDIUM)
  status              VirFindingStatus @default(OPEN)
  priority            Int              @default(0)
  title               String
  description         String           @db.Text
  dueDate             DateTime?
  vesselResponse      String?          @db.Text
  shoreFeedback       String?          @db.Text
  isCarriedOver       Boolean          @default(false)
  carriedFromFindingId String?
  ownerUserId         String?
  createdById         String?
  closedById          String?
  closedAt            DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  inspection        VirInspection        @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  question          VirTemplateQuestion? @relation(fields: [questionId], references: [id])
  carriedFromFinding VirFinding?         @relation("VirFindingCarryover", fields: [carriedFromFindingId], references: [id])
  carriedFindings   VirFinding[]         @relation("VirFindingCarryover")
  ownerUser         User?                @relation("VirFindingOwner", fields: [ownerUserId], references: [id])
  createdBy         User?                @relation("VirFindingCreatedBy", fields: [createdById], references: [id])
  closedBy          User?                @relation("VirFindingClosedBy", fields: [closedById], references: [id])
  correctiveActions VirCorrectiveAction[]
  photos            VirPhoto[]

  @@index([inspectionId, status])
  @@index([findingType, severity])
  @@index([dueDate])
}

model VirPhoto {
  id           String    @id @default(cuid())
  inspectionId String?
  findingId    String?
  answerId     String?
  url          String    @db.Text
  storageKey   String?
  caption      String?
  fileName     String?
  contentType  String?
  fileSizeKb   Int?
  takenAt      DateTime?
  uploadedById String?
  createdAt    DateTime  @default(now())

  inspection VirInspection? @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  finding    VirFinding?    @relation(fields: [findingId], references: [id], onDelete: Cascade)
  answer     VirAnswer?     @relation(fields: [answerId], references: [id], onDelete: Cascade)
  uploadedBy User?          @relation("VirPhotoUploadedBy", fields: [uploadedById], references: [id])

  @@index([inspectionId])
  @@index([findingId])
  @@index([answerId])
}

model VirCorrectiveAction {
  id               String                    @id @default(cuid())
  findingId        String
  actionText       String                    @db.Text
  ownerUserId      String?
  targetDate       DateTime?
  completedAt      DateTime?
  status           VirCorrectiveActionStatus @default(OPEN)
  completionRemark String?                   @db.Text
  verificationRemark String?                 @db.Text
  verifiedById     String?
  verifiedAt       DateTime?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  finding    VirFinding @relation(fields: [findingId], references: [id], onDelete: Cascade)
  ownerUser  User?      @relation("VirActionOwner", fields: [ownerUserId], references: [id])
  verifiedBy User?      @relation("VirActionVerifiedBy", fields: [verifiedById], references: [id])

  @@index([status])
  @@index([targetDate])
}

model VirSignOff {
  id          String         @id @default(cuid())
  inspectionId String
  stage       VirSignOffStage
  approved    Boolean        @default(false)
  actorUserId String?
  actorName   String?
  actorRole   String?
  comment     String?        @db.Text
  signedAt    DateTime       @default(now())

  inspection VirInspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  actorUser  User?         @relation(fields: [actorUserId], references: [id])

  @@index([inspectionId, stage])
}

model VirImportSession {
  id               String          @id @default(cuid())
  vesselId         String?
  inspectionTypeId String?
  sourceFileName   String
  sourceUrl        String?         @db.Text
  sourceSystem     String?
  sourceType       String          @default("PDF")
  status           VirImportStatus @default(QUEUED)
  modelName        String?         @default("gpt-4o")
  extractedAt      DateTime?
  confidenceAvg    Float?
  rawTextHash      String?
  payload          Json?
  createdById      String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  vessel         Vessel?           @relation(fields: [vesselId], references: [id], onDelete: SetNull)
  inspectionType VirInspectionType? @relation(fields: [inspectionTypeId], references: [id], onDelete: SetNull)
  createdBy      User?             @relation("VirImportCreatedBy", fields: [createdById], references: [id])
  fieldReviews   VirImportFieldReview[]
  inspections    VirInspection[]

  @@index([status])
  @@index([createdAt])
}

model VirImportFieldReview {
  id            String   @id @default(cuid())
  importSessionId String
  entityType    String
  fieldPath     String
  aiValue       String?  @db.Text
  finalValue    String?  @db.Text
  confidence    Float?
  accepted      Boolean?
  reviewerId    String?
  reviewedAt    DateTime?
  createdAt     DateTime @default(now())

  importSession VirImportSession @relation(fields: [importSessionId], references: [id], onDelete: Cascade)
  reviewer      User?            @relation("VirImportReviewer", fields: [reviewerId], references: [id])

  @@index([importSessionId, fieldPath])
}
